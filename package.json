{
  "name": "heatprint",
  "version": "1.0.0",
  "description": "Turn user interactions into generative art. Track clicks, movements, scrolls, and hovers — render them as heatmaps, constellations, flow fields, topographic maps, and particle trails. Beautiful data visualization from real behavior.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "node test/run.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "heatmap", "generative-art", "interaction", "analytics", "visualization",
    "canvas", "mouse-tracking", "click-map", "data-art", "creative-coding",
    "flow-field", "constellation", "topographic", "particle", "heatprint"
  ],
  "author": "0xDragoon",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/dragoon0x/heatprint" },
  "homepage": "https://dragoon0x.github.io/heatprint/",
  "sideEffects": false
}
